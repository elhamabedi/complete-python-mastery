   "source": [
    "### Exercise – Variable Number of Arguments\n",
    "\n",
    "Write a function named `multiple` that takes any number of arguments and returns the product of all of them.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "c232d5d4",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "1200\n"
     ]
    }
   ],
   "source": [
    "def multiple(*args):\n",
    "    results = 1\n",
    "    for i in args:\n",
    "        results*=i\n",
    "    return results\n",
    "\n",
    "print(multiple(100, 3, 4))"
   ]
  }
 ],
